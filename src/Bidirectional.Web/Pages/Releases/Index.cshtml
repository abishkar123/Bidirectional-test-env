@page
@model Bidirectional.Web.Pages.Releases.ReleasesModel
@{
    ViewData["Title"] = "Releases";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-rocket me-2 text-primary"></i>Releases</h1>
    <span class="text-muted small">@Model.Releases.Count release(s) in audit trail</span>
</div>

@if (Model.Error is not null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.Error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Run</th>
                    <th>Version</th>
                    <th>Commit</th>
                    <th>Branch</th>
                    <th>Actor</th>
                    <th>Deployed (UTC)</th>
                    <th>Slot swap</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Releases)
                {
                    <tr>
                        <td><span class="badge bg-secondary">#@r.RunNumber</span></td>
                        <td><code>@r.Version</code></td>
                        <td><code>@r.ShortCommit</code></td>
                        <td>@r.Branch</td>
                        <td>@r.Actor</td>
                        <td class="text-muted small">@r.DeployedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            @if (r.SlotSwap)
                            {
                                <span class="badge bg-success"><i class="bi bi-arrow-left-right me-1"></i>Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Releases.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No releases found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
