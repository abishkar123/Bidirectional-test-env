@page
@model Bidirectional.Web.Pages.Policy.PolicyModel
@{
    ViewData["Title"] = "Policy Compliance";
    var nonCompliant = Model.Entries.Count(p => !p.IsCompliant);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-shield-check me-2 text-success"></i>Policy Compliance</h1>
    @if (Model.Entries.Count > 0)
    {
        <span class="badge @(nonCompliant == 0 ? "bg-success" : "bg-danger") fs-6">
            @nonCompliant non-compliant
        </span>
    }
</div>

@if (Model.Error is not null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.Error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Resource</th>
                    <th>Policy</th>
                    <th>State</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Entries)
                {
                    <tr class="@(!p.IsCompliant ? "table-danger" : "")">
                        <td><code class="small">@p.Resource</code></td>
                        <td class="small">@p.Policy</td>
                        <td>
                            @if (p.IsCompliant)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>Compliant</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-lg me-1"></i>Non-compliant</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Entries.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No policy data found. Run a deployment to generate a snapshot.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
