@page
@model Bidirectional.Web.Pages.Scans.ScansModel
@{
    ViewData["Title"] = "Scan Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-bug me-2 text-warning"></i>Scan Results</h1>
    <span class="text-muted small">@Model.Results.Count file(s) in scan-results container</span>
</div>

@if (Model.Error is not null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.Error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Run</th>
                    <th>File</th>
                    <th class="text-end">Size</th>
                    <th>Uploaded (UTC)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Results)
                {
                    <tr>
                        <td><span class="badge bg-secondary">#@s.RunNumber</span></td>
                        <td><code class="small">@s.BlobName</code></td>
                        <td class="text-end text-muted small">@ByteFormatter.Format(s.SizeBytes)</td>
                        <td class="text-muted small">@s.LastModified.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
                @if (!Model.Results.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No scan results found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

