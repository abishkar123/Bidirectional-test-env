@page
@model Bidirectional.Web.Pages.Sbom.SbomModel
@{
    ViewData["Title"] = "SBOM Archive";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-file-earmark-code me-2 text-info"></i>SBOM Archive</h1>
    <span class="text-muted small">@Model.Sboms.Count SBOM(s) archived</span>
</div>

@if (Model.Error is not null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.Error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Run</th>
                    <th>File</th>
                    <th>Signed</th>
                    <th>Archived (UTC)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Sboms)
                {
                    <tr>
                        <td><span class="badge bg-secondary">#@s.RunNumber</span></td>
                        <td><code class="small">@s.DisplayName</code></td>
                        <td>
                            @if (s.IsSigned)
                            {
                                <span class="badge bg-success" title="cosign keyless bundle present">
                                    <i class="bi bi-patch-check-fill me-1"></i>cosign
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">unsigned</span>
                            }
                        </td>
                        <td class="text-muted small">@s.LastModified.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
                @if (!Model.Sboms.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No SBOMs found. They are generated automatically on each release.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
