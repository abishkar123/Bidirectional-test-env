@page
@model Bidirectional.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-circle display-1 text-danger"></i>
    <h1 class="mt-3">Something went wrong</h1>
    <p class="text-muted">Request ID: <code>@Model.RequestId</code></p>
    <a asp-page="/Index" class="btn btn-primary">Back to Dashboard</a>
</div>
