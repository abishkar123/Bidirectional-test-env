@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Platform Dashboard</h1>
    <span class="text-muted small">Updated @Model.LoadedAt.ToString("u")</span>
</div>

@if (Model.Error is not null)
{
    <div class="alert alert-warning d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <span>Could not load storage data: @Model.Error</span>
    </div>
}

<!-- KPI row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-rocket fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalReleases</div>
                    <div class="text-muted small">Total Releases</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-shield-check fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.CompliantPolicies<span class="fs-6 text-muted">/@Model.TotalPolicies</span></div>
                    <div class="text-muted small">Policies Compliant</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-file-earmark-code fs-4 text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalSboms</div>
                    <div class="text-muted small">SBOMs Archived</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-bug fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalScans</div>
                    <div class="text-muted small">Scan Results</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Audit container table + Latest release side by side -->
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-archive me-2"></i>Audit Storage Containers
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Container</th>
                            <th class="text-end">Blobs</th>
                            <th class="text-end">Size</th>
                            <th>Last Modified</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.ContainerSummaries)
                        {
                            <tr>
                                <td>
                                    <i class="bi bi-lock-fill text-secondary me-1" style="font-size:.75rem"></i>
                                    <code class="text-body">@c.Name</code>
                                </td>
                                <td class="text-end">@c.BlobCount</td>
                                <td class="text-end text-muted small">@ByteFormatter.Format(c.TotalBytes)</td>
                                <td class="text-muted small">
                                    @(c.LastModified.HasValue ? c.LastModified.Value.ToString("dd MMM yyyy HH:mm") : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-clock-history me-2"></i>Latest Release
            </div>
            <div class="card-body">
                @if (Model.LatestRelease is not null)
                {
                    var r = Model.LatestRelease;
                    <dl class="row mb-0 small">
                        <dt class="col-5 text-muted">Run</dt>
                        <dd class="col-7">#@r.RunNumber</dd>
                        <dt class="col-5 text-muted">Version</dt>
                        <dd class="col-7">@r.Version</dd>
                        <dt class="col-5 text-muted">Commit</dt>
                        <dd class="col-7"><code>@r.ShortCommit</code></dd>
                        <dt class="col-5 text-muted">Branch</dt>
                        <dd class="col-7">@r.Branch</dd>
                        <dt class="col-5 text-muted">Actor</dt>
                        <dd class="col-7">@r.Actor</dd>
                        <dt class="col-5 text-muted">Deployed</dt>
                        <dd class="col-7">@r.DeployedAt.ToString("dd MMM yyyy HH:mm 'UTC'")</dd>
                        <dt class="col-5 text-muted">Slot swap</dt>
                        <dd class="col-7">
                            @if (r.SlotSwap)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </dd>
                    </dl>
                    <a asp-page="/Releases/Index" class="btn btn-sm btn-outline-primary mt-3">
                        View all releases
                    </a>
                }
                else
                {
                    <p class="text-muted mb-0">No releases found.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Policy compliance summary -->
@if (Model.PolicyEntries.Count > 0)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent border-bottom fw-semibold">
            <i class="bi bi-shield-check me-2"></i>Latest Policy Compliance Snapshot
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0 small">
                <thead class="table-light">
                    <tr>
                        <th>Resource</th>
                        <th>Policy</th>
                        <th>State</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.PolicyEntries)
                    {
                        <tr>
                            <td class="text-truncate" style="max-width:300px" title="@p.Resource">
                                <code>@p.Resource</code>
                            </td>
                            <td>@p.Policy</td>
                            <td>
                                @if (p.IsCompliant)
                                {
                                    <span class="badge bg-success">Compliant</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Non-compliant</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-end">
            <a asp-page="/Policy/Index" class="btn btn-sm btn-outline-secondary">Full policy report</a>
        </div>
    </div>
}

